# Copy this file to `.env` and fill in your real API keys and settings.
# Values shown here are examples or defaults; DO NOT commit secrets.

# LLM Providers
GOOGLE_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434  # only needed when using Ollama

# Search & scraping providers
SERPER_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
CRAWLBASE_TOKEN=
CRAWLBASE_JS_TOKEN=

# Anti-detect / browser automation
CAMOUFOX_ENDPOINT=http://localhost:5000/execute  # replace with your Camoufox server URL (ws or http API)
# CAMOUFOX_CLI_PATH=/full/path/to/python -m camoufox  # optional explicit CLI path

# MCP
# MCP_CONFIG_PATH=/full/path/to/mcp.json

# Harvester tuning
HARVESTER_MAX_LINKS=1000
HARVESTER_MAX_CONCURRENCY=8
HARVESTER_SOURCE_TIMEOUT_SECONDS=120
HARVESTER_WRITER_BATCH_SIZE=50
HARVESTER_QUEUE_SIZE=5000
HARVESTER_PER_QUERY_LIMIT=25
HARVESTER_MIN_QUALITY_SCORE=0.35
HARVESTER_EXPANSION_SEED_LIMIT=12
HARVESTER_EXPANSION_PER_SEED_LIMIT=25
HARVESTER_ENABLE_SERPER=true
HARVESTER_ENABLE_FIRECRAWL=true
HARVESTER_ENABLE_BROWSER_DISCOVERY=true
HARVESTER_ENABLE_CRAWLBASE=true
HARVESTER_ENABLE_SERPAPI=false
HARVESTER_ENABLE_CAMOUFOX=false

# Scraper tuning
SCRAPER_MAX_CONCURRENCY=6
SCRAPER_SOURCE_TIMEOUT_SECONDS=90
SCRAPER_MAX_TARGETS_PER_RUN=250
SCRAPER_MAX_RETRIES_PER_TARGET=3
SCRAPER_ALLOW_EXISTING_REUSE=true
SCRAPER_REUSE_EXISTING_DAYS=7
SCRAPER_ENABLED_BACKENDS=generic_http,firecrawl,crawlbase,camoufox
# Legacy per-backend toggles are still supported, but the CSV above is now the preferred single-source override.
SCRAPER_ENABLE_GENERIC_HTTP=true
SCRAPER_ENABLE_FIRECRAWL=true
SCRAPER_ENABLE_CRAWLBASE=true
SCRAPER_ENABLE_CAMOUFOX=true

# Sentiment tuning
SENTIMENT_PROVIDER=huggingface
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
SENTIMENT_DEVICE=
SENTIMENT_BATCH_SIZE=16
SENTIMENT_MAX_CONCURRENCY=4
SENTIMENT_MAX_DOCUMENTS_PER_RUN=500
SENTIMENT_MAX_TEXT_CHARS=4000
SENTIMENT_POSITIVE_THRESHOLD=0.6
SENTIMENT_NEGATIVE_THRESHOLD=0.4
SENTIMENT_INCLUDE_TOPIC_CONTEXT=true
SENTIMENT_TOPIC_CONTEXT_WEIGHT=0.3
SENTIMENT_CUSTOM_KEYWORDS_POSITIVE=
SENTIMENT_CUSTOM_KEYWORDS_NEGATIVE=
SENTIMENT_LLM_PLAN_ENABLED=true
SENTIMENT_LLM_PLAN_SAMPLE_SIZE=10
SENTIMENT_LLM_FALLBACK_ENABLED=true
SENTIMENT_LLM_FALLBACK_SAMPLE_SIZE=10
SENTIMENT_LLM_FALLBACK_MAX_CHARS=2000
SENTIMENT_MIN_CONFIDENCE_THRESHOLD=0.5
SENTIMENT_AUTO_RETRY_LOW_CONFIDENCE=true

# Agent runtime resilience (per-agent overrides also supported)
AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_RETRIES=1
AGENT_CIRCUIT_BREAKER_THRESHOLD=3
AGENT_CIRCUIT_BREAKER_COOLDOWN_SECONDS=600

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_ENABLED=true
